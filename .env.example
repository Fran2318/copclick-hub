# Copiá a .env (local) o cargá estas variables en Railway.
# Railway define PORT automáticamente.
PORT=8080

# Supabase del ECOSISTEMA (xpglkncnekmcpxpeaznk) → tablas print_clients / print_jobs.
# La service_role la sacás de ese proyecto: Settings → API → service_role (SECRETA).
ECOSYSTEM_SUPABASE_URL=https://xpglkncnekmcpxpeaznk.supabase.co
ECOSYSTEM_SERVICE_KEY=pega_aqui_la_service_role_del_ecosistema

# Clave para los endpoints /admin del Hub (inventá una larga y aleatoria).
ADMIN_KEY=pon_una_clave_larga_aqui
